# HyperFlow secrets only.
# Public Arc/Circle/runtime settings live in config/hyperflow.config.json.

# Optional: seller-side x402 facilitator key.
# This is not the Circle Agent Wallet key. Agent Wallets are operated by Circle CLI sessions.
# Only needed if you run `npm run serve` for the local paid-service facilitator.
X402_FACILITATOR_PK=

# Circle CCTP source-chain signer used by the agent loop.
CONSUMER_PK=

# Standalone CCTP CLI signer, used only by: npm run cctp -- <amount>
CCTP_WALLET_PK=

# Hyperliquid API wallet private key.
HL_API_WALLET_PK=

# Nebius Token Factory API key. Required for the live Nebius reasoner.
NEBIUS_API_KEY=

# Secondary model provider API key. Used only after primary review request failure.
OPENAI_API_KEY=

# Telegram bot secrets.
TG_BOT_TOKEN=
TG_CHAT_ID=
